#include <iostream>
#include <vector>
#include <fstream>
using namespace std;

void displayScores(vector<int> scores) {
    cout << "\nScore List\n";

    for (int i = 0; i < scores.size(); i++) {
        cout << "Score-" << i + 1
             << " : " << scores[i] << endl;
    }
}

int displayTotal(vector<int> scores) {
    int total = 0;

    for (int i = 0; i < scores.size(); i++) {
        total += scores[i];
    }

    return total;
}

int displayHighest(vector<int> scores) {
    int max = scores[0];

    for (int i = 1; i < scores.size(); i++) {
        if (scores[i] > max) {
            max = scores[i];
        }
    }

    return max;
}

int displayLowest(vector<int> scores) {
    int min = scores[0];

    for (int i = 1; i < scores.size(); i++) {
        if (scores[i] < min) {
            min = scores[i];
        }
    }

    return min;
}

int main() {

    string name;
    int count;

    vector<int> scores;

    cout << "===== STUDENT SCORE SYSTEM =====\n\n";

    cout << "Name : ";
    cin >> name;

    cout << "Number of Scores : ";
    cin >> count;

    for (int i = 0; i < count; i++) {

        int n;

        cout << "Score-" << i + 1 << " : ";
        cin >> n;

        scores.push_back(n);
    }

    displayScores(scores);

    int total = displayTotal(scores);
    double average = (double)total / scores.size();

    cout << "\n===== RESULT =====\n";

    cout << "Name : " << name << endl;
    cout << "Total : " << total << endl;
    cout << "Average : " << average << endl;
    cout << "Highest Score : "
         << displayHighest(scores) << endl;

    cout << "Lowest Score : "
         << displayLowest(scores) << endl;

    ofstream file("student_scores.txt", ios::app);

    file << "====================\n";
    file << "Name : " << name << endl;
    file << "Total : " << total << endl;
    file << "Average : " << average << endl;
    file << "Highest Score : "
         << displayHighest(scores) << endl;

    file << "Lowest Score : "
         << displayLowest(scores) << endl;

    file.close();

    cout << "\n===== FILE CONTENT =====\n";

    ifstream read("student_scores.txt");

    string text;

    while (getline(read, text)) {
        cout << text << endl;
    }

    read.close();

    return 0;
}
